# TINA — copy to .env and fill in values

# Webhook URL for TINA alerts — create a separate webhook in your TINA Discord channel
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Bot token for the TINA Discord application — discord.com/developers/applications
DISCORD_BOT_TOKEN=YOUR_BOT_TOKEN

# Restrict TINA slash commands to one channel (right-click channel → Copy Channel ID)
TINA_BOT_CHANNEL_ID=
