# SINSI — copy to .env and fill in values

# Webhook URL — Channel Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Optional: second webhook for watchlist add/remove messages (same as above if not splitting)
DISCORD_WATCHLIST_WEBHOOK_URL=

# Bot token — discord.com/developers/applications → your app → Bot → Token
DISCORD_BOT_TOKEN=YOUR_BOT_TOKEN

# Restrict slash commands to one channel (right-click channel → Copy Channel ID)
ALLOWED_CHANNEL_ID=
